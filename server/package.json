{
	"name": "glossary-app",
	"version": "1.0.0",
	"description": "",
	"type": "commonjs",
	"main": "index.ts",
	"scripts": {
		"dev": "ts-node src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"migrate:up": "node -r ts-node/register node_modules/.bin/migrate-mongo up -f src/boot/initMigrateMongo.ts",
		"migrate:down": "node -r ts-node/register node_modules/.bin/migrate-mongo down -f src/boot/initMigrateMongo.ts",
		"migrate:status": "node -r ts-node/register node_modules/.bin/migrate-mongo status -f src/boot/initMigrateMongo.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	},
	"dependencies": {
		"@fastify/autoload": "6.3.1",
		"@fastify/cors": "11.2.0",
		"@fastify/mongodb": "10.0.0",
		"@fastify/swagger": "9.7.0",
		"@fastify/swagger-ui": "5.2.5",
		"@fastify/type-provider-typebox": "6.1.0",
		"dotenv": "17.2.3",
		"fastify": "5.7.2",
		"fastify-plugin": "5.1.0",
		"migrate-mongo": "14.0.7"
	}
}
